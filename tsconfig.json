{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@landing/*": ["./resources/landing/*"],
      "@monitoreo/*": ["./resources/monitoreo/*"]
    }
  },
  "include": [
    "resources/landing/**/*.ts",
    "resources/landing/**/*.tsx",
    "resources/landing/**/*.d.ts",
    "resources/monitoreo/**/*.ts",
    "resources/monitoreo/**/*.tsx",
    "resources/monitoreo/**/*.d.ts"
  ]
}
